# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Database Configuration (MySQL)
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/subscription_management

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production-12345

# SMTP Configuration (for OTP email delivery)
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-gmail-address@gmail.com
# SMTP_PASSWORD=your-google-app-password
# SMTP_FROM_EMAIL=your-gmail-address@gmail.com
# SMTP_FROM_NAME=SubSync
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-google-app-password
SMTP_FROM_EMAIL=your-gmail-address@gmail.com
SMTP_FROM_NAME=SubSync
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Razorpay Configuration (real customer payments)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Gemini Configuration (customer AI assistant)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# CORS Configuration
CORS_ORIGINS=http://localhost:3002,http://localhost:3003,http://127.0.0.1:3002,http://127.0.0.1:3003

# Environment
ENVIRONMENT=development
